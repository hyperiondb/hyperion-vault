NODE_ID=1
VAULT_PEERS=1=127.0.0.1:7400
VAULT_API_PORT=8200
VAULT_DB_PATH=vault.redb
VAULT_ALLOWED_IPS=127.0.0.1/32
VAULT_TRUST_PROXY=false
VAULT_READ_CONSISTENCY=local
VAULT_KMS_MODE=local
VAULT_LOCAL_MASTER_KEY=CrbvPp787kTip4iPLb4NJfk5ww/j1ingx/a4PaLPGWg=
VAULT_ROTATION_POLL_SECS=15
VAULT_DEK_CACHE_TTL_SECS=300
VAULT_KMS_MAX_RETRIES=5
# Re-wrap DEKs onto new CMK material after an AWS KMS key rotation. Ship a new
# release with this OFF, roll every node, then set it true (so the new raft
# commands are never sent to a node that cannot decode them). Needs IAM
# kms:ListKeyRotations + kms:ReEncrypt* in addition to GenerateDataKey/Decrypt.
VAULT_KMS_REWRAP_ENABLED=false
VAULT_KMS_REWRAP_POLL_SECS=86400
VAULT_KMS_REWRAP_MAX_PER_SEC=10
RUST_LOG=info
